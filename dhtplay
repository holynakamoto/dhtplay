#!/usr/bin/env python3
"""dhtplay — stream a BitTorrent infohash via DHT in VLC."""

import argparse
import base64
import os
import queue
import re
import socket
import subprocess
import sys
import threading
from urllib.parse import quote

TRACKERS = [
    "udp://tracker.opentrackr.org:1337/announce",
    "udp://open.demonii.com:1337",
    "udp://tracker.openbittorrent.com:80/announce",
    "udp://tracker.torrent.eu.org:451/announce",
    "wss://tracker.btorrent.xyz",
]

WEBTORRENT_CANDIDATES = [
    "/opt/homebrew/bin/webtorrent",
    "/usr/local/bin/webtorrent",
    os.path.expanduser("~/.local/bin/webtorrent"),
]


def parse_infohash(raw):
    """Return normalised lowercase hex infohash, or raise ValueError."""
    s = raw.strip()

    # Accept a full magnet URI and pull out the btih value
    if s.lower().startswith("magnet:"):
        m = re.search(r'urn:btih:([A-Za-z0-9]+)', s, re.IGNORECASE)
        if not m:
            raise ValueError("cannot find urn:btih in magnet URI")
        s = m.group(1)

    # 40-char hex (SHA-1 v1)
    if re.fullmatch(r'[0-9A-Fa-f]{40}', s):
        return s.lower()

    # 32-char base32 (BitTorrent often encodes the 20-byte SHA-1 in base32)
    if re.fullmatch(r'[A-Za-z2-7]{32}', s):
        try:
            return base64.b32decode(s.upper()).hex()
        except Exception:
            raise ValueError(f"base32 decode failed for {s!r}")

    raise ValueError(
        f"unrecognised infohash {s!r} — expected 40 hex chars or 32 base32 chars"
    )


def build_magnet(ih_hex, *, trackers=(), display_name=None):
    """Return a magnet URI string."""
    parts = [f"magnet:?xt=urn:btih:{ih_hex}"]
    if display_name:
        parts.append(f"dn={quote(display_name)}")
    for tr in trackers:
        parts.append(f"tr={quote(tr, safe=':/')}")
    return "&".join(parts)


def find_webtorrent(override=None):
    """Return path to webtorrent executable, or None."""
    if override:
        return override if _executable(override) else None
    for path in WEBTORRENT_CANDIDATES:
        if _executable(path):
            return path
    try:
        r = subprocess.run(["which", "webtorrent"], capture_output=True, text=True)
        if r.returncode == 0:
            p = r.stdout.strip()
            if p:
                return p
    except OSError:
        pass
    return None


def _executable(path):
    return os.path.isfile(path) and os.access(path, os.X_OK)


def get_lan_ip():
    """Return the LAN IP of this machine, or '127.0.0.1' as fallback."""
    # On macOS, query physical interfaces directly to avoid VPN tunnels winning
    # the routing decision when using the UDP socket trick.
    for iface in ("en0", "en1", "en2"):
        try:
            result = subprocess.run(
                ["ipconfig", "getifaddr", iface],
                capture_output=True, text=True, timeout=2,
            )
            ip = result.stdout.strip()
            if ip:
                return ip
        except (OSError, subprocess.TimeoutExpired):
            continue
    s = None
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        return s.getsockname()[0]
    except OSError:
        return "127.0.0.1"
    finally:
        if s is not None:
            s.close()


def _find_stream_url(proc, port, timeout=30):
    """Scan proc.stdout for the first URL containing port; return it or None on timeout."""
    q = queue.Queue()
    pattern = re.compile(r'https?://\S*' + re.escape(str(port)) + r'\S*')

    def _reader():
        try:
            matched = False
            for line in proc.stdout:
                if not matched:
                    m = pattern.search(line)
                    if m:
                        q.put(m.group(0))
                        matched = True
        except Exception:
            pass

    threading.Thread(target=_reader, daemon=True).start()
    try:
        return q.get(timeout=timeout)
    except queue.Empty:
        return None


def _render_qr(url):
    """Render a QR code for url via qrencode; skip silently if qrencode is absent."""
    try:
        subprocess.run(["qrencode", "-t", "ansiutf8", url])
    except (OSError, FileNotFoundError):
        pass


def main(argv=None):
    ap = argparse.ArgumentParser(
        prog="dhtplay",
        description="Play a BitTorrent infohash via DHT in VLC",
    )
    ap.add_argument(
        "infohash",
        help="40-hex or 32-base32 infohash, or a full magnet URI",
    )
    tracker_grp = ap.add_mutually_exclusive_group()
    tracker_grp.add_argument(
        "--trackers",
        dest="trackers",
        action="store_true",
        default=True,
        help="include common public trackers in the magnet URI (default)",
    )
    tracker_grp.add_argument(
        "--no-trackers",
        dest="trackers",
        action="store_false",
        help="omit trackers from the magnet URI",
    )
    ap.add_argument("--name", "-n", metavar="TITLE", help="display name (dn=) for the torrent")
    ap.add_argument(
        "--dry-run", "-d",
        action="store_true",
        help="print the magnet URI and exit without opening VLC",
    )
    ap.add_argument("--webtorrent", metavar="PATH", help="path to webtorrent executable")
    ap.add_argument(
        "--url", "-u",
        action="store_true",
        help="start the HTTP streaming server only (no local player) and print a URL pointing directly to the first file; open it on another device via Media → Open Network Stream",
    )
    ap.add_argument(
        "--port", "-p",
        type=int,
        default=8888,
        metavar="PORT",
        help="HTTP streaming server port (default: 8888)",
    )
    args = ap.parse_args(argv)

    # --- validate / normalise -------------------------------------------------
    try:
        ih_hex = parse_infohash(args.infohash)
    except ValueError as exc:
        ap.error(str(exc))

    # --- build URI ------------------------------------------------------------
    trackers = TRACKERS if args.trackers else []
    magnet = build_magnet(ih_hex, trackers=trackers, display_name=args.name)

    if args.dry_run:
        print(magnet)
        return 0

    # --- locate webtorrent ----------------------------------------------------
    wt = find_webtorrent(args.webtorrent)
    if not wt:
        print(
            "dhtplay: webtorrent not found — install with:  npm install -g webtorrent-cli",
            file=sys.stderr,
        )
        return 2

    # --- launch ---------------------------------------------------------------
    wt_cmd = [wt, magnet, "--vlc", "-p", str(args.port)]

    if args.url:
        wt_cmd_http = [wt, magnet, "-p", str(args.port), "--keep-seeding"]
        try:
            proc = subprocess.Popen(wt_cmd_http, stdout=subprocess.PIPE, text=True)
        except OSError as exc:
            print(f"dhtplay: failed to launch webtorrent: {exc}", file=sys.stderr)
            return 3

        lan_ip = get_lan_ip()
        raw_url = _find_stream_url(proc, args.port, timeout=30)
        if raw_url is None:
            if proc.poll() is not None:
                print("dhtplay: webtorrent exited unexpectedly", file=sys.stderr)
            else:
                print("dhtplay: timed out waiting for stream URL", file=sys.stderr)
            return 3

        target_url = re.sub(r'https?://(?:localhost|127\.0\.0\.1)', f'http://{lan_ip}', raw_url)

        sock = None
        try:
            sock = socket.create_connection((lan_ip, args.port), timeout=2)
        except OSError:
            print(
                f"dhtplay: streaming server not reachable at {lan_ip}:{args.port}"
                " — is webtorrent bound to 0.0.0.0?",
                file=sys.stderr,
            )
            return 3
        finally:
            if sock is not None:
                sock.close()

        print(f"▶  {target_url}")
        _render_qr(target_url)

        try:
            proc.wait()
        except KeyboardInterrupt:
            proc.terminate()
        return 0

    try:
        subprocess.Popen(wt_cmd)
    except OSError as exc:
        print(f"dhtplay: failed to launch webtorrent: {exc}", file=sys.stderr)
        return 3

    print(f"▶  {magnet}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
